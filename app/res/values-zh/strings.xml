  <string formatted="false" name="alarm_pref_not_used">不用於此警報類型</string>
  <string formatted="false" name="pref_alarm_threshold_summary">警報閾值：</string>
  <string formatted="false" name="pref_alarm_threshold_help">對於充電和溫度警報，需要設定溫度
    或將觸發警報的電量水準。</string>
