  <string name="status_bar_chip_settings" formatted="false">Állapotsor chip</string>
  <string name="status_bar_chip_settings_summary" formatted="false">A Live Updates chip tartalmának beállítása</string>
  <string name="status_bar_chip_settings_help" formatted="false">Android 16+ rendszeren, Live Updates mellett beállíthatod, mit jelenítsen meg az állapotsor chip.</string>
  <string name="current_hack_settings" formatted="false">Áram (mA) hack</string>
